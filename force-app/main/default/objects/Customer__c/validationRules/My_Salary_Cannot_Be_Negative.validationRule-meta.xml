<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>My_Salary_Cannot_Be_Negative</fullName>
    <active>true</active>
    <errorConditionFormula>My_Salary__c &lt; 0</errorConditionFormula>
    <errorDisplayField>My_Salary__c</errorDisplayField>
    <errorMessage>My Salary cannot be less than zero.</errorMessage>
</ValidationRule>
